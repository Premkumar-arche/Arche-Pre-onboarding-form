    <div class="nav-logo">
      <img src="data:image/png;base64," alt="Arche Global">
    </div>
  </nav>

  <div class="page-body">
    <div class="form-container">

      <div class="form-header">
        <div class="header-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
          </svg>
        </div>
        <div class="header-text">
          <h1>Arche Pre-Onboarding Form</h1>
          <p>Personal Information</p>
        </div>
      </div>

      <form id="personalInfoForm" novalidate>
        <div class="form-content">

          <div class="section-title">Basic Details</div>
          <div class="form-grid">
            <div class="form-group"><label>Salutation<span class="required">*</span></label><select name="salutation" id="salutation" required><option value="">Select</option><option>Mr</option><option>Ms</option><option>Mrs</option><option>Dr</option></select><span class="error-message" id="salutation-error">Required</span></div>
            <div class="form-group"><label>First Name<span class="required">*</span></label><input type="text" name="first_name" id="first_name" pattern="[A-Za-z\s]+" required><span class="error-message" id="first_name-error">Letters only</span></div>
            <div class="form-group"><label>Last Name<span class="required">*</span></label><input type="text" name="last_name" id="last_name" pattern="[A-Za-z\s]+" required><span class="error-message" id="last_name-error">Letters only</span></div>
            <div class="form-group"><label>Father's Name<span class="required">*</span></label><input type="text" name="father_name" id="father_name" pattern="[A-Za-z\s]+" required><span class="error-message" id="father_name-error">Letters only</span></div>
            <div class="form-group"><label>Date of Birth<span class="required">*</span></label><input type="date" name="dob" id="dob" required><span class="error-message" id="dob-error">Age must be 18–65</span></div>
            <div class="form-group"><label>Age</label><input type="number" name="age" id="age" min="18" max="65" readonly></div>
            <div class="form-group"><label>Gender<span class="required">*</span></label><select name="gender" id="gender" required><option value="">Select</option><option>Male</option><option>Female</option><option>Others</option></select><span class="error-message" id="gender-error">Required</span></div>
            <div class="form-group"><label>Blood Group<span class="required">*</span></label><select name="blood_group" id="blood_group" required><option value="">Select</option><option>A+</option><option>A-</option><option>B+</option><option>B-</option><option>O+</option><option>O-</option><option>AB+</option><option>AB-</option></select><span class="error-message" id="blood_group-error">Required</span></div>
            <div class="form-group"><label>Marital Status<span class="required">*</span></label><select name="marital_status" id="marital_status" required><option value="">Select</option><option>Married</option><option>Single</option></select><span class="error-message" id="marital_status-error">Required</span></div>
            <div class="form-group"><label>Marriage Date</label><input type="date" name="marriage_date" id="marriage_date"></div>
          </div>

          <div class="section-title">Contact Information</div>
          <div class="form-grid">
            <div class="form-group"><label>Mobile Number<span class="required">*</span></label><input type="tel" name="mobile_number" id="mobile_number" pattern="[6-9][0-9]{9}" maxlength="10" required><span class="error-message" id="mobile_number-error">10-digit mobile (6–9 start)</span></div>
            <div class="form-group"><label>Alternate Contact<span class="required">*</span></label><input type="tel" name="alt_contact_number" id="alt_contact_number" pattern="[6-9][0-9]{9}" maxlength="10" required><span class="error-message" id="alt_contact_number-error">10-digit mobile</span></div>
            <div class="form-group"><label>Personal Email<span class="required">*</span></label><input type="email" name="personal_email" id="personal_email" required><span class="error-message" id="personal_email-error">Valid email (gmail, yahoo, outlook, hotmail, arche.global)</span></div>
            <div class="form-group"><label>Confirm Email<span class="required">*</span></label><input type="email" name="confirm_email" id="confirm_email" required><span class="error-message" id="confirm_email-error">Emails must match</span></div>
          </div>

          <div class="section-title">Identity Documents</div>
          <div class="form-grid">
            <div class="form-group"><label>PAN Number<span class="required">*</span></label><input type="text" name="pan" id="pan" maxlength="10" style="text-transform:uppercase;" placeholder="ABCDE1234F" required><span class="error-message" id="pan-error">e.g. ABCDE1234F</span></div>
            <div class="form-group"><label>Aadhar Number<span class="required">*</span></label><input type="text" name="aadhar" id="aadhar" pattern="[0-9]{12}" maxlength="12" required><span class="error-message" id="aadhar-error">12 digits</span></div>
            <div class="form-group"><label>UAN Number</label><input type="text" name="uan" id="uan" pattern="[0-9]{12}" maxlength="12"><span class="error-message" id="uan-error">12 digits</span></div>
          </div>

          <div class="section-title">Address Details</div>
          <div class="section-subtitle">Present Address</div>
          <div class="form-grid">
            <div class="form-group full-width"><label>Present Address Line 1<span class="required">*</span></label><input type="text" name="present_address_line1" id="present_address_line1" required><span class="error-message" id="present_address_line1-error">Required</span></div>
            <div class="form-group full-width"><label>Present Address Line 2</label><input type="text" name="present_address_line2" id="present_address_line2"></div>
            <div class="form-group"><label>Present City<span class="required">*</span></label><input type="text" name="present_city" id="present_city" pattern="[A-Za-z\s]+" required><span class="error-message" id="present_city-error">Letters only</span></div>
            
            <div class="form-group">
              <label>Present State<span class="required">*</span></label>
              <select name="present_state" id="present_state" required>
                <option value="">Select State</option>
                <option value="Andhra Pradesh">Andhra Pradesh</option>
                <option value="Arunachal Pradesh">Arunachal Pradesh</option>
                <option value="Assam">Assam</option>
                <option value="Bihar">Bihar</option>
                <option value="Chhattisgarh">Chhattisgarh</option>
                <option value="Goa">Goa</option>
                <option value="Gujarat">Gujarat</option>
                <option value="Haryana">Haryana</option>
                <option value="Himachal Pradesh">Himachal Pradesh</option>
                <option value="Jharkhand">Jharkhand</option>
                <option value="Karnataka">Karnataka</option>
                <option value="Kerala">Kerala</option>
                <option value="Madhya Pradesh">Madhya Pradesh</option>
                <option value="Maharashtra">Maharashtra</option>
                <option value="Manipur">Manipur</option>
                <option value="Meghalaya">Meghalaya</option>
                <option value="Mizoram">Mizoram</option>
                <option value="Nagaland">Nagaland</option>
                <option value="Odisha">Odisha</option>
                <option value="Punjab">Punjab</option>
                <option value="Rajasthan">Rajasthan</option>
                <option value="Sikkim">Sikkim</option>
                <option value="Tamil Nadu">Tamil Nadu</option>
                <option value="Telangana">Telangana</option>
                <option value="Tripura">Tripura</option>
                <option value="Uttar Pradesh">Uttar Pradesh</option>
                <option value="Uttarakhand">Uttarakhand</option>
                <option value="West Bengal">West Bengal</option>
                <option value="Andaman and Nicobar Islands">Andaman and Nicobar Islands</option>
                <option value="Chandigarh">Chandigarh</option>
                <option value="Dadra and Nagar Haveli and Daman and Diu">Dadra and Nagar Haveli and Daman and Diu</option>
                <option value="Delhi">Delhi</option>
                <option value="Lakshadweep">Lakshadweep</option>
                <option value="Puducherry">Puducherry</option>
              </select>
              <span class="error-message" id="present_state-error">Required</span>
            </div>

            <div class="form-group"><label>Present Pin<span class="required">*</span></label><input type="text" name="present_pin" id="present_pin" pattern="[0-9]{6}" maxlength="6" required><span class="error-message" id="present_pin-error">6-digit PIN</span></div>
            <div class="form-group"><label>Present Country<span class="required">*</span></label><input type="text" name="present_country" id="present_country" value="India" required readonly></div>
          </div>

          <div class="form-grid">
            <div class="toggle-group">
              <label class="toggle-label" for="same_as_present">Same as Present Address</label>
              <label class="toggle-switch">
                <input type="checkbox" id="same_as_present">
                <span class="toggle-slider"></span>
              </label>
            </div>
          </div>

          <div class="section-subtitle">Permanent Address</div>
          <div class="form-grid">
            <div class="form-group full-width"><label>Permanent Address Line 1<span class="required">*</span></label><input type="text" name="permanent_address_line1" id="permanent_address_line1" required><span class="error-message" id="permanent_address_line1-error">Required</span></div>
            <div class="form-group full-width"><label>Permanent Address Line 2</label><input type="text" name="permanent_address_line2" id="permanent_address_line2"></div>
            <div class="form-group"><label>Permanent City<span class="required">*</span></label><input type="text" name="permanent_city" id="permanent_city" pattern="[A-Za-z\s]+" required><span class="error-message" id="permanent_city-error">Letters only</span></div>
            
            <div class="form-group">
              <label>Permanent State<span class="required">*</span></label>
              <select name="permanent_state" id="permanent_state" required>
                <option value="">Select State</option>
                <option value="Andhra Pradesh">Andhra Pradesh</option>
                <option value="Arunachal Pradesh">Arunachal Pradesh</option>
                <option value="Assam">Assam</option>
                <option value="Bihar">Bihar</option>
                <option value="Chhattisgarh">Chhattisgarh</option>
                <option value="Goa">Goa</option>
                <option value="Gujarat">Gujarat</option>
                <option value="Haryana">Haryana</option>
                <option value="Himachal Pradesh">Himachal Pradesh</option>
                <option value="Jharkhand">Jharkhand</option>
                <option value="Karnataka">Karnataka</option>
                <option value="Kerala">Kerala</option>
                <option value="Madhya Pradesh">Madhya Pradesh</option>
                <option value="Maharashtra">Maharashtra</option>
                <option value="Manipur">Manipur</option>
                <option value="Meghalaya">Meghalaya</option>
                <option value="Mizoram">Mizoram</option>
                <option value="Nagaland">Nagaland</option>
                <option value="Odisha">Odisha</option>
                <option value="Punjab">Punjab</option>
                <option value="Rajasthan">Rajasthan</option>
                <option value="Sikkim">Sikkim</option>
                <option value="Tamil Nadu">Tamil Nadu</option>
                <option value="Telangana">Telangana</option>
                <option value="Tripura">Tripura</option>
                <option value="Uttar Pradesh">Uttar Pradesh</option>
                <option value="Uttarakhand">Uttarakhand</option>
                <option value="West Bengal">West Bengal</option>
                <option value="Andaman and Nicobar Islands">Andaman and Nicobar Islands</option>
                <option value="Chandigarh">Chandigarh</option>
                <option value="Dadra and Nagar Haveli and Daman and Diu">Dadra and Nagar Haveli and Daman and Diu</option>
                <option value="Delhi">Delhi</option>
                <option value="Lakshadweep">Lakshadweep</option>
                <option value="Puducherry">Puducherry</option>
              </select>
              <span class="error-message" id="permanent_state-error">Required</span>
            </div>

            <div class="form-group"><label>Permanent Pin<span class="required">*</span></label><input type="text" name="permanent_pin" id="permanent_pin" pattern="[0-9]{6}" maxlength="6" required><span class="error-message" id="permanent_pin-error">6-digit PIN</span></div>
            <div class="form-group"><label>Permanent Country<span class="required">*</span></label><input type="text" name="permanent_country" id="permanent_country" value="India" required readonly></div>
          </div>

          <div class="section-title">Bank Details</div>
          <div class="form-grid">
            <div class="form-group"><label>Bank Name<span class="required">*</span></label><input type="text" name="bank_name" id="bank_name" required><span class="error-message" id="bank_name-error">Required</span></div>
            <div class="form-group"><label>Bank Account Number<span class="required">*</span></label><input type="text" name="bank_account_number" id="bank_account_number" pattern="[0-9]+" required><span class="error-message" id="bank_account_number-error">Digits only</span></div>
            <div class="form-group"><label>IFSC Code<span class="required">*</span></label><input type="text" name="ifsc_code" id="ifsc_code" style="text-transform:uppercase;" required></div>
          </div>

          <div class="section-title">Emergency Contact</div>
          <div class="form-grid">
            <div class="form-group"><label>Emergency Contact Name<span class="required">*</span></label><input type="text" name="emergency_contact_name" id="emergency_contact_name" pattern="[A-Za-z\s]+"><span class="error-message" id="emergency_contact_name-error">Letters only</span></div>
            <div class="form-group"><label>Emergency Contact Number<span class="required">*</span></label><input type="tel" name="emergency_contact_no" id="emergency_contact_no" pattern="[6-9][0-9]{9}" maxlength="10"><span class="error-message" id="emergency_contact_no-error">10-digit mobile</span></div>
          </div>

          <input type="hidden" name="present_address" id="present_address">
          <input type="hidden" name="permanent_address" id="permanent_address">

          <div class="button-group">
            <button type="submit" id="submitBtn"><span>Submit Information</span></button>
          </div>

        </div>
      </form>
    </div>
  </div>

  <script>
    const validators = {
      text: v => /^[A-Za-z\s]+$/.test(v),
      mobile: v => /^[6-9]\d{9}$/.test(v),
      pan: v => /^[A-Z]{5}\d{4}[A-Z]$/.test(v),
      aadhar: v => /^\d{12}$/.test(v),
      uan: v => /^\d{12}$/.test(v) || v === '',
      pin: v => /^\d{6}$/.test(v),
      account: v => /^\d+$/.test(v),
      email: v => {
        const allowed = ['gmail.com','yahoo.com','outlook.com','hotmail.com','arche.global'];
        const domain = v.trim().toLowerCase().split('@')[1];
        return domain && allowed.includes(domain);
      }
    };

    function validateField(field) {
      let val = field.value.trim();
      if (field.id === 'pan') val = val.toUpperCase();
      const err = document.getElementById(field.id + '-error');
      let valid = true;
      if (field.required && !val) valid = false;
      else if (val) {
        if (['first_name','last_name','father_name','present_city','permanent_city','emergency_contact_name'].includes(field.id)) valid = validators.text(val);
        else if (['mobile_number','alt_contact_number','emergency_contact_no'].includes(field.id)) valid = validators.mobile(val);
        else if (field.id === 'pan') valid = validators.pan(val);
        else if (field.id === 'aadhar') valid = validators.aadhar(val);
        else if (field.id === 'uan') valid = validators.uan(val);
        else if (field.id.includes('pin')) valid = validators.pin(val);
        else if (field.id === 'bank_account_number') valid = validators.account(val);
        else if (field.id === 'personal_email') valid = validators.email(val);
      }
      if (field.id === 'pan') field.value = val;
      field.classList.toggle('error', !valid);
      field.classList.toggle('success', valid && val);
      if (err) err.classList.toggle('show', !valid);
      return valid;
    }

    function validateEmailPair() {
      const p = document.getElementById('personal_email');
      const c = document.getElementById('confirm_email');
      const ep = document.getElementById('personal_email-error');
      const ec = document.getElementById('confirm_email-error');
      const pv = p.value.trim(); const cv = c.value.trim();
      const pValid = pv && validators.email(pv);
      const cValid = cv && cv === pv && validators.email(cv);
      p.classList.toggle('error',!pValid); p.classList.toggle('success',pValid);
      ep.classList.toggle('show',!pValid); ep.textContent = pValid ? '' : 'Invalid domain';
      c.classList.toggle('error',!cValid); c.classList.toggle('success',cValid);
      ec.classList.toggle('show',!cValid); ec.textContent = cValid ? '' : 'Emails must match';
      return pValid && cValid;
    }

    document.getElementById('dob').addEventListener('change', function(){
      const dob = new Date(this.value);
      const today = new Date();
      let age = today.getFullYear() - dob.getFullYear();
      const m = today.getMonth() - dob.getMonth();
      if (m < 0 || (m === 0 && today.getDate() < dob.getDate())) age--;
      document.getElementById('age').value = age;
      const valid = age >= 18 && age <= 65;
      this.classList.toggle('error',!valid); this.classList.toggle('success',valid);
      document.getElementById('dob-error').classList.toggle('show',!valid);
    });

    document.getElementById('same_as_present').addEventListener('change', function(){
      if(this.checked){
        ['address_line1','address_line2','city','state','pin','country'].forEach(f=>{
          document.getElementById('permanent_'+f).value = document.getElementById('present_'+f).value;
          
          const permField = document.getElementById('permanent_'+f);
          if (permField) validateField(permField);
        });
      }
    });

    function buildAddress(prefix){
      const parts = [
        document.getElementById(prefix+'_address_line1').value.trim(),
        document.getElementById(prefix+'_address_line2').value.trim(),
        document.getElementById(prefix+'_city').value.trim(),
        document.getElementById(prefix+'_state').value.trim(),
        document.getElementById(prefix+'_pin').value.trim(),
        document.getElementById(prefix+'_country').value.trim()
      ];
      return parts.filter(Boolean).join(', ');
    }

    document.getElementById('personalInfoForm').addEventListener('submit', async function(e){
      e.preventDefault();
      let allValid = true;

      this.querySelectorAll('input[required], select[required]').forEach(f => {
        if (f.id === 'personal_email' || f.id === 'confirm_email'){
          if (!validateEmailPair()) allValid = false;
        } else {
          if (!validateField(f)) allValid = false;
        }
      });

      if (!allValid) return alert('Please fix all errors before submitting.');

      document.getElementById('present_address').value = buildAddress('present');
      document.getElementById('permanent_address').value = buildAddress('permanent');

      const formData = new FormData(this);
      const btn = document.getElementById('submitBtn');
      btn.disabled = true;
      btn.innerHTML = '<span>Submitting...</span>';

      try {
        await fetch('https://n8nhost771.app.n8n.cloud/webhook/onboarding-form', {
          method: 'POST',
          body: formData,
          mode: 'no-cors',
          credentials: 'omit'
        });
        alert('Submitted successfully!');
      } catch (err) {
        alert('Submitted (no-cors mode – check n8n logs)');
      } finally {
        btn.disabled = false;
        btn.innerHTML = '<span>Submit Information</span>';
      }
    });

    document.querySelectorAll('input, select').forEach(el => {
      el.addEventListener('blur', () => {
        if (el.id === 'personal_email' || el.id === 'confirm_email') validateEmailPair();
        else validateField(el);
      });
      el.addEventListener('input', () => {
        if (el.classList.contains('error') || el.tagName.toLowerCase() === 'select'){
          if (el.id === 'personal_email' || el.id === 'confirm_email') validateEmailPair();
          else validateField(el);
        }
      });
    });
  </script>
</body>
</html>
